---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const guides = (await getCollection('guides')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const guideHref = (slug: string) => `${base}/${slug}`;
---

<BaseLayout
  title="abdemon GFX guides"
  description="Long-form, opinionated walkthroughs for cinematic edit workflows."
>
  <div class="wrap">
    <header class="hero">
      <div class="eyebrow">Field Guides · Index</div>
      <h1><em>abdemon</em><br />GFX Guides</h1>
      <p class="lede">
        Long-form, opinionated walkthroughs of specific creative workflows. One recipe per guide,
        end to end, no scrubbing through video.
      </p>
    </header>

    <section class="catalog">
      {
        guides.map((g) => (
          <a class="catalog-card" href={guideHref(g.id)}>
            <Image
              class="catalog-cover"
              src={g.data.caseStudy.after}
              alt={g.data.caseStudy.afterAlt}
              widths={[480, 800]}
              sizes="(min-width: 760px) 480px, 100vw"
            />
            <div class="catalog-meta">
              <div class="catalog-eyebrow">{g.data.eyebrow}</div>
              <div class="catalog-title" set:html={g.data.titleHtml.replace(/<br\s*\/?>/g, ' ')} />
              <div class="catalog-lede">{g.data.lede[0]}</div>
              <div class="catalog-tags">
                <span>{g.data.meta.difficulty}</span>
                <span>·</span>
                <span>{g.data.meta.time}</span>
                <span>·</span>
                <span>{g.data.meta.tools}</span>
              </div>
            </div>
          </a>
        ))
      }
    </section>

    <footer>
      <span>Field Guides · Index</span>
      <span>{guides.length} {guides.length === 1 ? 'guide' : 'guides'}</span>
      <span>End of file</span>
    </footer>
  </div>
</BaseLayout>

<style>
  .catalog {
    padding: 60px 0 80px;
    border-top: 1px solid var(--rule);
    display: grid;
    gap: 1px;
    background: var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .catalog-card {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 28px;
    background: var(--bg);
    padding: 24px;
    text-decoration: none;
    color: var(--ink);
    transition: background 200ms;
  }
  .catalog-card:hover {
    background: var(--bg-2);
  }
  .catalog-cover {
    width: 100%;
    height: auto;
    aspect-ratio: 1750 / 1400;
    object-fit: cover;
    border: 1px solid var(--rule);
  }
  .catalog-meta {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 4px;
  }
  .catalog-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--teal);
  }
  .catalog-title {
    font-family: var(--serif);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(28px, 3.4vw, 40px);
    line-height: 1.05;
    color: var(--ink);
  }
  .catalog-title :global(em) {
    font-style: normal;
    font-weight: 500;
    color: var(--amber);
  }
  .catalog-lede {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink-dim);
    max-width: 56ch;
  }
  .catalog-tags {
    display: flex;
    gap: 8px;
    margin-top: 6px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  @media (max-width: 760px) {
    .catalog-card {
      grid-template-columns: 1fr;
      gap: 18px;
    }
    .catalog-cover {
      max-width: 100%;
    }
  }
</style>
