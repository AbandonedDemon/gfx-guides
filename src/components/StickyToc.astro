---
interface StepRef {
  id: string;
  num: string;
  title: string;
}

interface Props {
  steps: StepRef[];
}

const { steps } = Astro.props;
---

<nav class="sticky-toc" aria-label="Steps">
  <div class="sticky-toc-label">Steps</div>
  <ol>
    {
      steps.map((s) => (
        <li>
          <a href={`#${s.id}`} data-step={s.id}>
            <span class="num">{s.num}</span>
            <span class="title">{s.title}</span>
          </a>
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .sticky-toc {
    display: none;
  }
  @media (min-width: 1280px) {
    .sticky-toc {
      display: block;
      position: fixed;
      top: 50%;
      left: 24px;
      transform: translateY(-50%);
      width: 200px;
      z-index: 50;
      pointer-events: auto;
    }
    .sticky-toc-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--ink-faint);
      margin-bottom: 14px;
      padding-left: 12px;
    }
    .sticky-toc ol {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .sticky-toc li {
      margin: 0;
      padding: 0;
    }
    .sticky-toc a {
      display: grid;
      grid-template-columns: 24px 1fr;
      gap: 10px;
      align-items: baseline;
      padding: 6px 12px;
      border-left: 1px solid var(--rule);
      text-decoration: none;
      color: var(--ink-faint);
      transition: color 0.18s ease, border-color 0.18s ease;
    }
    .sticky-toc a:hover {
      color: var(--ink-dim);
    }
    .sticky-toc a .num {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.12em;
    }
    .sticky-toc a .title {
      font-family: var(--serif);
      font-size: 13px;
      line-height: 1.35;
      font-style: italic;
    }
    .sticky-toc a.is-active {
      border-left-color: var(--amber);
      color: var(--ink);
    }
    .sticky-toc a.is-active .title {
      color: var(--amber);
      font-style: normal;
    }
  }
</style>

<script>
  const links = new Map<string, HTMLAnchorElement>();
  document.querySelectorAll<HTMLAnchorElement>('.sticky-toc a[data-step]').forEach((a) => {
    const id = a.dataset.step;
    if (id) links.set(id, a);
  });

  if (links.size > 0) {
    const setActive = (id: string) => {
      links.forEach((a) => a.classList.remove('is-active'));
      links.get(id)?.classList.add('is-active');
    };

    const obs = new IntersectionObserver(
      (entries) => {
        entries
          .filter((e) => e.isIntersecting)
          .forEach((e) => setActive(e.target.id));
      },
      { rootMargin: '-40% 0px -55% 0px', threshold: 0 }
    );
    document.querySelectorAll<HTMLElement>('section.step[id]').forEach((s) => obs.observe(s));

    document.querySelectorAll<HTMLAnchorElement>('.sticky-toc a[data-step]').forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const id = a.dataset.step;
        if (!id) return;
        document.getElementById(id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }
</script>
